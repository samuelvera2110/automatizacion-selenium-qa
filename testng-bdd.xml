<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="BDD Cucumber Suite" verbose="1" parallel="none">

    <listeners>
        <listener class-name="com.example.report.ExtentTestListener"/>
    </listeners>

    <test name="OpenCart Cucumber BDD">
        <classes>
            <class name="com.example.opencart.runner.OpencartRunner"/>
        </classes>
    </test>

    <test name="ParaBank Cucumber BDD">
        <classes>
            <class name="com.example.parabank.runner.ParabankRunner"/>
        </classes>
    </test>

</suite>